{
  "name": "mars-ai-grp2",
  "private": true,
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "sync:newsletter-unsubscribed": "npm --prefix backend run sync:newsletter-unsubscribed",
    "seed:movies50": "npm --prefix backend run seed:movies50",
    "seed:movies:normalize-submission": "npm --prefix backend run seed:movies:normalize-submission",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "npm --prefix backend run test",
    "test:frontend": "npm --prefix frontend run test",
    "translate": "node scripts/translate.js",
    "translate:watch": "node scripts/translate.js --watch"
  },
  "dependencies": {
    "deepl-node": "^1.24.0"
  }
}